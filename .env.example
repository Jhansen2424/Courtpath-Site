# Stripe API Keys (get from https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Stripe Price IDs (create products at https://dashboard.stripe.com/products)
# Bronze: $4 one-time payment
STRIPE_PRICE_BRONZE=price_...

# Silver: $25/month subscription
STRIPE_PRICE_SILVER=price_...

# Gold: $21/month subscription (starting price)
STRIPE_PRICE_GOLD=price_...

# Platinum: $240/year subscription (starting price)
STRIPE_PRICE_PLATINUM=price_...

# App URL (used for Stripe checkout success/cancel redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Courtpath API
COURTPATH_API_URL=https://courtpath-production.up.railway.app
COURTPATH_COMPANY_ID=b335c44b-2ba0-490a-993f-55837e7b9f99

# Encryption key for password stored in Stripe metadata (generate with: openssl rand -hex 32)
SIGNUP_ENCRYPTION_KEY=your_32_byte_hex_key_here

# Mailer (Gmail app password for contact form → sends to support@courtpath.com)
MAILER_AUTH_USER=your_email@example.com
MAILER_AUTH_PASS=your_app_password
